# claude-proxy environment variables
# Copy this file to .env (or export directly) and adjust as needed.

# API ports
# CLAUDE_PROXY_PORT=3456
# CLAUDE_PROXY_STATUS_PORT=3458

# Path to Claude Code CLI binary (must be logged in: `claude auth status`)
# CLAUDE_BIN=claude

# Claude model aliases (use `opus[1m]` / `sonnet[1m]` for 1M context variants)
# OPUS_MODEL=opus
# SONNET_MODEL=sonnet
# HAIKU_MODEL=haiku

# Timeouts (milliseconds)
# IDLE_TIMEOUT_MS=120000
# HARD_TIMEOUT_MS=1200000

# Concurrency caps
# MAX_PER_CHANNEL=2
# MAX_GLOBAL=20

# State file
# STATE_PATH=state.json

# Keyword-to-alias substitution. Comma separated. Leave empty to disable.
# REWRITE_TERMS=OpenClaw,openclaw
